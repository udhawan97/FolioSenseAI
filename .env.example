# .env.example — TEMPLATE — safe to commit to GitHub
# Copy this to .env and fill in your real values
ANTHROPIC_API_KEY=your_anthropic_api_key_here
SECRET_KEY=generate_a_random_string_here
DEBUG=True
DATABASE_URL=sqlite:///./database/portfolio.db
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Optional: comma-separated tickers to add when POST /api/portfolio/seed runs.
# Leave blank for a clean slate.
DEFAULT_HOLDINGS=
