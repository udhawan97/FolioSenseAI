# .env.example — TEMPLATE — safe to commit to GitHub
# Copy this to .env and fill in your real values
ANTHROPIC_API_KEY=your_anthropic_api_key_here
SECRET_KEY=generate_a_random_string_here
DEBUG=True  # Set to False in production
DATABASE_URL=sqlite:///./database/portfolio.db
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Optional: comma-separated tickers to add when the default portfolio is created.
# Leave blank for a clean slate.
DEFAULT_HOLDINGS=

# Optional: the contact address sent to SEC EDGAR when fetching filings. The SEC
# requires software to identify itself and rejects anything that doesn't. Leave
# blank to use the project maintainer's address; set your own to speak for
# yourself. It goes to the SEC and nowhere else — it is not a login.
FOLIO_SEC_CONTACT=
