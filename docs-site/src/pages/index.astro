		<script define:vars={{ API: `https://api.github.com/repos/${REPO}/releases/latest`, TAGS_API: `https://api.github.com/repos/${REPO}/git/refs/tags` }}>
			const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			// ── OS-aware CTA ──────────────────────────────────────────────
			const os = (() => {
				const p = (navigator.userAgentData?.platform || navigator.platform || navigator.userAgent || '').toLowerCase();
				return p.includes('mac') ? 'mac' : p.includes('win') ? 'win' : 'other';
			})();
			if (os !== 'other') {
				document.querySelectorAll('.btn[data-os]').forEach((b) => {
					b.classList.add(b.getAttribute('data-os') === os ? 'is-preferred' : 'is-secondary');
				});
			}

			// ── Live release metadata (graceful fallback to static links) ──
			const fmtBytes = (n) => n ? (n >= 1048576 ? `${(n / 1048576).toFixed(0)} MB` : `${(n / 1024).toFixed(0)} KB`) : '';
			const fmtDate = (iso) => { try { return new Date(iso).toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' }); } catch { return ''; } };
			const pick = (assets, ext) => assets.find((a) => a.name.toLowerCase().endsWith(ext));
			function applyRelease(data) {
				if (!data || !data.assets) return;
				const dmg = pick(data.assets, '.dmg'), exe = pick(data.assets, '.exe');
				const setBtn = (id, a) => { const b = document.getElementById(id); if (!b || !a) return; b.href = a.browser_download_url; const m = b.querySelector('[data-role="meta"]'); if (m) m.textContent = `${data.tag_name} · ${fmtBytes(a.size)}`; };
				setBtn('dl-mac', dmg); setBtn('dl-win', exe);
				document.querySelectorAll('[data-role="card-dl"]').forEach((el) => { const a = el.getAttribute('data-os') === 'mac' ? dmg : exe; if (a) el.href = a.browser_download_url; });
				const strip = document.getElementById('release-strip');
				if (strip) {
					const set = (r, t) => { const el = strip.querySelector(`[data-role="${r}"]`); if (el) el.textContent = t; };
					set('version', data.tag_name || '—'); set('date', fmtDate(data.published_at));
					const link = strip.querySelector('[data-role="release-link"]'); if (link && data.html_url) link.href = data.html_url;
					strip.hidden = false;
					if (data.tag_name) {
						fetch(`${TAGS_API}/${data.tag_name}`, { headers: { Accept: 'application/vnd.github+json' } })
							.then((r) => (r.ok ? r.json() : null))
							.then((ref) => { if (!ref?.object) return null; if (ref.object.type === 'commit') return ref.object.sha; return fetch(ref.object.url).then((r) => (r.ok ? r.json() : null)).then((t) => t?.object?.sha || null); })
							.then((sha) => { if (sha) { const el = strip.querySelector('[data-role="sha"]'); if (el) { el.textContent = sha.slice(0, 7); const wrap = el.closest('.chip'); if (wrap) wrap.hidden = false; } } })
							.catch(() => {});
					}
				}
			}
			(async () => {
				const key = 'fs-release-latest';
				try {
					const c = sessionStorage.getItem(key);
					if (c) { applyRelease(JSON.parse(c)); return; }
					const r = await fetch(API, { headers: { Accept: 'application/vnd.github+json' } });
					if (!r.ok) return;
					const data = await r.json();
					sessionStorage.setItem(key, JSON.stringify(data));
					applyRelease(data);
				} catch { /* offline → static fallbacks stay */ }
			})();

			// ── Copy buttons ──────────────────────────────────────────────
			document.querySelectorAll('.copy').forEach((btn) => {
				btn.addEventListener('click', async () => {
					const text = btn.closest('[data-copy]')?.getAttribute('data-copy') || '';
					try {
						await navigator.clipboard.writeText(text);
						const prev = btn.textContent; btn.textContent = '✓ Copied'; btn.classList.add('copied');
						setTimeout(() => { btn.textContent = prev; btn.classList.remove('copied'); }, 1400);
					} catch { /* clipboard blocked */ }
				});
			});

			// ── Reveals (with blur-resolve) ───────────────────────────────
			if (reduce || !('IntersectionObserver' in window)) {
				document.querySelectorAll('.reveal').forEach((el) => el.classList.add('shown'));
			} else {
				const io = new IntersectionObserver((es) => es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('shown'); io.unobserve(e.target); } }), { threshold: 0.14 });
				document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
			}

			// ── Per-act chapter tint ──────────────────────────────────────
			if ('IntersectionObserver' in window) {
				const tintIO = new IntersectionObserver((es) => {
					es.forEach((e) => { if (e.isIntersecting) document.body.setAttribute('data-hue', e.target.getAttribute('data-hue') || 'cyan'); });
				}, { rootMargin: '-45% 0px -45% 0px', threshold: 0 });
				document.querySelectorAll('.act[data-hue]').forEach((el) => tintIO.observe(el));
			}

			// ── Shared active-visibility controller: videos + loop pausing ─
			if ('IntersectionObserver' in window) {
				const activeIO = new IntersectionObserver((es) => {
					es.forEach((e) => {
						const el = e.target;
						if (el.tagName === 'VIDEO') { if (reduce) return; e.isIntersecting ? el.play().catch(() => {}) : el.pause(); }
						else el.classList.toggle('in-view', e.isIntersecting);
					});
				}, { threshold: 0.35 });
				document.querySelectorAll('.demo-loop, .wf-stage, .artifact, #demo-card, .term-body').forEach((el) => activeIO.observe(el));
			}
			const demoCard = document.getElementById('demo-card');
			if (demoCard && !reduce) demoCard.classList.add('js-anim');
			if (reduce) document.querySelectorAll('.demo-loop').forEach((v) => v.setAttribute('controls', ''));

			// ── Hero: chip parallax + signal convergence + region tour ────
			const stage = document.getElementById('hero-stage');
			if (stage && !reduce && window.matchMedia('(pointer:fine)').matches) {
				const chips = stage.querySelectorAll('.chip-float');
				stage.addEventListener('pointermove', (e) => {
					const r = stage.getBoundingClientRect();
					const dx = (e.clientX - r.left) / r.width - 0.5, dy = (e.clientY - r.top) / r.height - 0.5;
					chips.forEach((c) => { const d = parseFloat(c.getAttribute('data-depth') || '0'); c.style.transform = `translate(${dx * d}px, ${dy * d}px)`; });
				});
				stage.addEventListener('pointerleave', () => chips.forEach((c) => { c.style.transform = ''; }));
			}
			const region = document.getElementById('spot-region'), regionTip = document.getElementById('spot-region-tip'), heroWindow = document.getElementById('hero-window');
			if (region && regionTip && heroWindow) {
				const hotspots = [
					{ x: 2, y: 12, w: 26, h: 22, label: 'Live value & today’s P&L' },
					{ x: 51, y: 12, w: 24, h: 20, label: 'What moved, in dollars' },
					{ x: 1, y: 36.5, w: 40, h: 41.5, label: 'Look-through sector exposure' },
					{ x: 42, y: 36.5, w: 57, h: 42, label: 'Today’s impact, in plain English' },
				];
				let hi = 0, timer = null, paused = false;
				const place = (h) => { region.style.left = h.x + '%'; region.style.top = h.y + '%'; region.style.width = h.w + '%'; region.style.height = h.h + '%'; regionTip.textContent = h.label; };
				place(hotspots[0]);
				if (!reduce) {
					region.classList.add('is-live');
					const step = () => { if (!paused) { hi = (hi + 1) % hotspots.length; place(hotspots[hi]); } };
					let started = false;
					heroWindow.addEventListener('pointerenter', () => { paused = true; });
					heroWindow.addEventListener('pointerleave', () => { paused = false; });
					if ('IntersectionObserver' in window) {
						new IntersectionObserver((es) => es.forEach((e) => {
							if (e.isIntersecting) { if (!timer) timer = setInterval(step, 3200); if (!started) { started = true; region.classList.add('show'); } }
							else { clearInterval(timer); timer = null; }
						}), { threshold: 0.25 }).observe(heroWindow);
					} else { region.classList.add('show'); timer = setInterval(step, 3200); }
				} else { region.classList.add('show'); }
			}

			// ── Workflow: active step drives the sticky stage ─────────────
			const wfStage = document.getElementById('wf-stage');
			if (wfStage && 'IntersectionObserver' in window) {
				const stepEls = [...document.querySelectorAll('.wf-step')];
				const wfIO = new IntersectionObserver((es) => {
					es.forEach((e) => {
						if (e.isIntersecting) {
							const n = e.target.getAttribute('data-step');
							wfStage.setAttribute('data-step', n);
							stepEls.forEach((s) => s.classList.toggle('is-active', s === e.target));
						}
					});
				}, { rootMargin: '-45% 0px -45% 0px', threshold: 0 });
				stepEls.forEach((s) => wfIO.observe(s));
			}

			// ── Terminal: tabs + type-in on first reveal ──────────────────
			const term = document.getElementById('terminal');
			if (term) {
				const tabs = term.querySelectorAll('.term-tab'), panes = term.querySelectorAll('.term-pane');
				const activate = (name) => {
					tabs.forEach((t) => t.classList.toggle('is-active', t.getAttribute('data-tab') === name));
					panes.forEach((p) => p.classList.toggle('is-active', p.getAttribute('data-tab') === name));
				};
				tabs.forEach((t) => t.addEventListener('click', () => activate(t.getAttribute('data-tab'))));
				if (!reduce && 'IntersectionObserver' in window) {
					const typeIO = new IntersectionObserver((es, ob) => es.forEach((e) => {
						if (e.isIntersecting) { term.classList.add('typed'); ob.disconnect(); }
					}), { threshold: 0.4 });
					typeIO.observe(term);
				} else { term.classList.add('typed'); }
			}

			// ── Senpai rail: scroll progress + section-aware bubbles ──────
			const rail = document.getElementById('rail'), orb = document.getElementById('rail-orb'),
				bubble = document.getElementById('rail-bubble'), railLive = document.getElementById('rail-live'),
				railDismiss = document.getElementById('rail-dismiss');
			const LINES = {
				'act-hero': 'I read the portfolio so you don’t stare at a red Tuesday alone.',
				'act-workflow': 'Three steps. I do the middle one.',
				'act-features': 'Beta 0.85 — you’ll lag the rip, dodge the worst of the dip.',
				'act-demo': 'Fake holdings. Real workflow. Commentary: complimentary.',
				'act-trust': 'Local-first. Your database never texts anyone.',
				'act-download': 'Pick your platform. I’ll behave. Mostly.',
				'act-updates': 'Updates knock first, back up your data, and wait for a yes.',
				'act-roadmap': 'More features are brewing. No dates — I’m an orb, not an oracle.',
				'act-dev': 'Or build me yourself. I’m flattered either way.',
			};
			if (rail && orb && bubble && localStorage.getItem('fs-rail') !== 'off') {
				rail.classList.add('on');
				let bubbleTimer = null, curAct = '';
				const showBubble = (text) => {
					bubble.textContent = text; bubble.hidden = false;
					requestAnimationFrame(() => bubble.classList.add('show'));
					if (railLive) railLive.textContent = text;
					clearTimeout(bubbleTimer);
					bubbleTimer = setTimeout(() => bubble.classList.remove('show'), 6000);
				};
				// progress: orb travels the rail with scroll
				let ticking = false;
				const onScroll = () => {
					if (ticking) return; ticking = true;
					requestAnimationFrame(() => {
						const p = Math.min(1, Math.max(0, window.scrollY / (document.body.scrollHeight - window.innerHeight)));
						orb.style.setProperty('--p', p);
						ticking = false;
					});
				};
				window.addEventListener('scroll', onScroll, { passive: true }); onScroll();
				if ('IntersectionObserver' in window) {
					const actIO = new IntersectionObserver((es) => es.forEach((e) => {
						if (e.isIntersecting && e.target.id !== curAct) {
							curAct = e.target.id;
							const line = LINES[curAct];
							if (line && !reduce) { orb.classList.remove('pulse'); void orb.offsetWidth; orb.classList.add('pulse'); showBubble(line); }
						}
					}), { rootMargin: '-45% 0px -45% 0px', threshold: 0 });
					document.querySelectorAll('.act[id]').forEach((el) => actIO.observe(el));
				}
				orb.addEventListener('click', () => { if (LINES[curAct]) showBubble(LINES[curAct]); });
				railDismiss?.addEventListener('click', () => { rail.classList.remove('on'); rail.classList.add('off'); localStorage.setItem('fs-rail', 'off'); });
			}

			// ── Footer Senpai one-liner: random on every load, click/tap to shuffle ──
				const quips = [
					'Not financial advice. Very much a dashboard.',
					'Your “diversified” portfolio is four tech stocks in a trench coat.',
					'The line went up. I have theories about why.',
					'Green Tuesday? I’ll take partial credit.',
					'More features are brewing. Dates? I plead the fifth.',
					'Updates knock before they enter. Very well-mannered software.',
					'Your data never left the building. I double-checked.',
					'I read the 10-K so your group chat doesn’t have to.',
					'Rebalancing: spring cleaning for people who own ETFs.',
					'Past performance guarantees nothing. Neither do I — but I’m charming.',
					'Dollar-cost averaging is just investing with the lights off. Calmly.',
					'I don’t predict the market. I narrate its mood swings.',
					'Beta 0.85: you’ll miss the moon, and most of the crater.',
					'Backed up, checksum-checked, and waiting for your yes. No rush.',
				];
				const egg = document.getElementById('senpai-egg');
				const quipBtn = document.getElementById('senpai-quip');
				const quipText = document.getElementById('senpai-quip-text');
				let qi = Math.floor(Math.random() * quips.length);
				const paintQuip = (animate) => {
					if (!quipText) return;
					quipText.textContent = quips[qi];
					if (animate && !reduce && quipBtn) { quipBtn.classList.remove('shuffled'); void quipBtn.offsetWidth; quipBtn.classList.add('shuffled'); }
				};
				const shuffleQuip = () => {
					if (quips.length > 1) { let n; do { n = Math.floor(Math.random() * quips.length); } while (n === qi); qi = n; }
					paintQuip(true);
				};
				paintQuip(false); // randomised first line on every refresh
				quipBtn?.addEventListener('click', shuffleQuip);
				egg?.addEventListener('click', shuffleQuip);
		</script>
	</body>
</html>
