---
/**
 * FolioSenseAI landing page — v3 "private cockpit".
 *
 * A single cinematic story told in acts (hero → workflow → features → demo →
 * trust → download → developer), narrated by a Senpai scroll companion. Real
 * retina app screenshots and recorded product loops anchor every claim.
 *
 * Architecture stays deliberately dependency-free: CSS/SVG motion + a small
 * amount of vanilla JS behind one IntersectionObserver-driven controller.
 * Release metadata is fetched client-side from the GitHub API with static
 * fallbacks, so downloads work with JS disabled or the API unreachable.
 */
import '../styles/landing.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const REPO = 'udhawan97/FolioSenseAI';
const GITHUB = `https://github.com/${REPO}`;
const RELEASES = `${GITHUB}/releases`;
const RELEASES_LATEST = `${RELEASES}/latest`;
const RAW = 'https://raw.githubusercontent.com';

const asset = (p) => `${base}/assets/${p}`;
const shot = (p) => `${base}/assets/shots/${p}`;
const demo = (p) => `${base}/assets/demos/${p}`;
const doc = (slug) => `${base}/${slug}/`;

const macCmd = `curl -fsSL ${RAW}/${REPO}/main/scripts/install-mac.sh | bash`;
const winCmd = `irm ${RAW}/${REPO}/main/scripts/install-win.ps1 | iex`;

// Act 3 — the three-step workflow.
const steps = [
  {
    n: 1, title: 'Add your holdings',
    body: 'Tickers, shares, cost basis — or a watchlist. No brokerage link, no sign-up.',
    senpai: 'Drop in VOO and AAPL. No brokerage link, no awkward data-hostage situation.',
  },
  {
    n: 2, title: 'It reads the whole picture',
    body: 'Exposure, risk, concentration, news, and market regime — computed on-device.',
    senpai: 'I checked risk, concentration, headlines, and whether your “diversification” is just tech in a trench coat.',
  },
  {
    n: 3, title: 'You get plain-English answers',
    body: 'Verdicts, drivers, and themes in language you can act on. Turn on Claude for narrated briefings.',
    senpai: 'Here’s the read: what changed, why it matters, and what to consider next.',
  },
];

// Act 4 — feature moments. Some carry a screenshot/video, some a pure artifact.
const features = [
  {
    key: 'risk', accent: 'teal', kicker: 'Risk analytics',
    title: 'See the risk behind the return',
    body: 'Scatter, correlation, concentration, and drawdown — every number explained in a plain-English line beneath it.',
    img: 'risk-analytics-demo.webp',
    alt: 'FolioSenseAI risk analytics: risk-return scatter, correlation matrix, and concentration dial.',
    senpai: 'Concentration check: five sectors, one ego.',
  },
  {
    key: 'verdicts', accent: 'amber', kicker: 'Hold / Add / Trim / Exit',
    title: 'A verdict for every position',
    body: 'Open a holding and its intelligence panel unfolds — rating, drivers, and what moved it today.',
    video: 'verdicts',
    alt: 'FolioSenseAI holdings table expanding a position into its full intelligence panel.',
  },
  {
    key: 'news', accent: 'cyan', kicker: 'News themes',
    title: 'Headlines, mapped to your holdings',
    body: 'Grouped, deduplicated, and themed — only the news that touches what you own or watch.',
    video: 'news-v2',
    alt: 'FolioSenseAI news feed with grouped, relevant headlines under each holding.',
    senpai: 'I read the news so it doesn’t read you.',
  },
];

// Act 8½ — the roadmap. Optimistic sneak peek, not a delivery promise.
// Each icon is a compact stroke SVG (inner markup only) coloured by the act accent.
const roadmap = [
  {
    status: 'Next up in the lab',
    title: 'Target weights & drift',
    body: 'Set the mix you’re aiming for, then see at a glance how far today’s prices have nudged you off plan.',
    icon: '<circle cx="12" cy="12" r="8.5"/><path d="M12 3.5v3M12 17.5v3M3.5 12h3M17.5 12h3"/><path d="M12 12l4-2.5"/>',
  },
  {
    status: 'On the radar',
    title: 'More than one portfolio',
    body: 'Give your retirement account and your fun-money account their own separate scoreboards.',
    icon: '<path d="M12 3 3 8l9 5 9-5-9-5Z"/><path d="M3 13l9 5 9-5"/>',
  },
  {
    status: 'On the radar',
    title: 'A verdict report card',
    body: 'The dashboard grading its own past Hold / Add / Trim calls over time — in public, no less.',
    icon: '<rect x="5" y="4" width="14" height="17" rx="2"/><path d="M9 4h6v3H9z"/><path d="M8.5 13l2 2 4-4"/>',
  },
  {
    status: 'Next up in the lab',
    title: 'Year-end realized recap',
    body: 'A tidy “what did I actually lock in this year?” summary for when tax season comes knocking.',
    icon: '<path d="M6 3h12v18l-3-2-3 2-3-2-3 2V3Z"/><path d="M9 8h6M9 12h6"/>',
  },
  {
    status: 'Being explored',
    title: 'Income & dividends view',
    body: 'A clear read on what your portfolio pays you back — the income side, not just the price side.',
    icon: '<circle cx="12" cy="12" r="8.5"/><path d="M12 7.5v9M9.6 9.6c0-1 1-1.6 2.4-1.6s2.4.6 2.4 1.6c0 2.2-4.8 1-4.8 3.2 0 1 1 1.6 2.4 1.6s2.4-.6 2.4-1.6"/>',
  },
  {
    status: 'Being explored',
    title: 'A what-if simulator',
    body: 'Preview a buy or a trim before you touch anything real. Regret-free rehearsals.',
    icon: '<path d="M4 7h9M17 7h3M4 17h3M11 17h9"/><circle cx="15" cy="7" r="2"/><circle cx="9" cy="17" r="2"/>',
  },
];
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>FolioSenseAI — Your portfolio, finally speaks back.</title>
		<meta name="description" content="Local-first portfolio intelligence for macOS and Windows. FolioSenseAI turns holdings, risk, news, and market context into plain-English portfolio reads — on your machine, Claude-optional, built for trust." />
		<link rel="icon" type="image/svg+xml" href={asset('folio-orbit-icon.svg')} />
		<meta property="og:title" content="FolioSenseAI — Your portfolio, finally speaks back." />
		<meta property="og:description" content="Local-first portfolio intelligence for macOS and Windows. Plain-English reads on holdings, risk, news, and market context." />
		<meta property="og:type" content="website" />
		<meta property="og:image" content={asset('og-hero.jpg')} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:image" content={asset('og-hero.jpg')} />
	</head>
	<body>
		<!-- Ambient canvas: financial grid + aurora, tinted per act. -->
		<div class="canvas" aria-hidden="true">
			<div class="canvas-grid"></div>
			<div class="canvas-aurora aurora-a"></div>
			<div class="canvas-aurora aurora-b"></div>
		</div>

		<header class="topbar">
			<a class="brand" href={base + '/'}>
				<img src={asset('folio-orbit-icon.svg')} alt="" width="28" height="28" />
				<span>FolioSenseAI</span>
			</a>
			<nav class="topnav">
				<a href={doc('get-started/introduction')}>Docs</a>
				<a href={RELEASES}>Releases</a>
				<a href={GITHUB} class="ghost">GitHub ↗</a>
			</nav>
		</header>

		<!-- Senpai scroll companion (desktop rail; inline cards on mobile). -->
		<aside class="rail" id="rail" aria-label="Senpai guide">
			<button class="rail-dismiss" id="rail-dismiss" type="button" aria-label="Hide guide">×</button>
			<div class="rail-track"></div>
			<div class="rail-orb" id="rail-orb">
				<img src={asset('folio-orbit-icon.svg')} alt="" width="30" height="30" />
			</div>
			<div class="rail-bubble" id="rail-bubble" hidden></div>
			<span class="sr-only" id="rail-live" aria-live="polite"></span>
		</aside>

		<main>
			<!-- ═══ ACT 1+2 · HERO ═══════════════════════════════════════════ -->
			<section class="hero act" id="act-hero" data-hue="cyan">
				<div class="hero-decor" aria-hidden="true">
					<div class="hero-glow"></div>
					<div class="hero-orb hero-orb-a"></div>
					<div class="hero-orb hero-orb-b"></div>
					<div class="hero-streak"></div>
					<img class="hero-glyph hero-glyph-mark" src={asset('folio-orbit-mark-dark-animated.svg')} alt="" width="360" height="360" />
					<span class="hero-line hero-line-a"></span>
					<span class="hero-dot hero-dot-1"></span>
					<span class="hero-dot hero-dot-2"></span>
					<span class="hero-dot hero-dot-3"></span>
					<span class="hero-dot hero-dot-4"></span>
				</div>

				<div class="hero-grid">
					<div class="hero-content">
						<span class="eyebrow reveal">Local-first portfolio intelligence</span>
						<h1 class="display reveal">Your portfolio, finally speaks&nbsp;back.</h1>
						<p class="lede reveal">
							FolioSenseAI turns holdings, risk, news, and market context into plain-English
							portfolio reads — running on your machine, Claude-optional, built for trust.
						</p>

						<div class="cta-row reveal">
							<a id="dl-mac" class="btn btn-primary" href={RELEASES_LATEST} data-os="mac">
								<span class="btn-icon btn-icon-mac" aria-hidden="true"></span>
								<span class="btn-copy">
									<span class="btn-title">Download for macOS</span>
									<span class="btn-sub" data-role="meta">Apple Silicon · .dmg</span>
								</span>
							</a>
							<a id="dl-win" class="btn btn-primary" href={RELEASES_LATEST} data-os="win">
								<span class="btn-icon btn-icon-win" aria-hidden="true"></span>
								<span class="btn-copy">
									<span class="btn-title">Download for Windows</span>
									<span class="btn-sub" data-role="meta">64-bit .exe installer</span>
								</span>
							</a>
						</div>

						<div class="action-pills reveal">
							<a class="pill-action" href={doc('get-started/introduction')}>
								<span class="pill-ic pill-ic-docs" aria-hidden="true"></span>View Docs
							</a>
							<a class="pill-action" href={GITHUB}>
								<span class="pill-ic pill-ic-github" aria-hidden="true"></span>GitHub
							</a>
							<a class="pill-action" href={RELEASES}>
								<span class="pill-ic pill-ic-notes" aria-hidden="true"></span>Release Notes
							</a>
							<details class="pill-dev">
								<summary class="pill-action"><span class="pill-ic pill-ic-dev" aria-hidden="true"></span>Development Builds</summary>
								<div class="dev-panel">
									<p>Rolling builds from the latest <code>main</code> merge. Unstable — for testing only.</p>
									<a href={`${RELEASES}/tag/latest-main`}>Get the latest-main build ↗</a>
								</div>
							</details>
						</div>

						<ul class="trust-strip reveal" aria-label="At a glance">
							<li class="badge"><span class="badge-dot" aria-hidden="true"></span>Local-first</li>
							<li class="badge"><span class="badge-dot" aria-hidden="true"></span>Claude optional</li>
							<li class="badge"><span class="badge-dot" aria-hidden="true"></span>Open source</li>
							<li class="badge"><span class="badge-dot" aria-hidden="true"></span>SHA256 verifiable</li>
						</ul>

						<div id="release-strip" class="release-strip reveal" hidden>
							<span class="chip chip-meta">
								<span class="chip-ic chip-ic-tag" aria-hidden="true"></span>
								<span data-role="version">—</span>
							</span>
							<span class="chip chip-meta">
								<span class="chip-ic chip-ic-cal" aria-hidden="true"></span>
								<span data-role="date">—</span>
							</span>
							<span class="chip chip-meta" hidden>
								<span class="chip-ic chip-ic-commit" aria-hidden="true"></span>
								<span data-role="sha">—</span>
							</span>
							<a class="chip chip-link" data-role="release-link" href={RELEASES_LATEST}>
								View release<span class="chip-arrow" aria-hidden="true">→</span>
							</a>
						</div>
					</div>

					<div class="hero-visual reveal" id="hero-stage" aria-hidden="true">
						<div class="product-preview">
							<div class="window-chrome grad-border" id="hero-window">
								<div class="window-bar"><span></span><span></span><span></span></div>
								<div class="hero-shot">
									<img src={shot('hero-cockpit-v3.webp')} width="2400" height="1508" fetchpriority="high"
										alt="The FolioSenseAI dashboard cockpit: total value, today's P&L, sector map, and today's impact for a demo portfolio." />
									<div class="pulse-line"></div>
									<div class="spot-region" id="spot-region">
										<span class="spot-region-tip" id="spot-region-tip"></span>
									</div>
								</div>
							</div>

							<div class="chip-float chip-float--tl" data-depth="7"><span class="dot dot-amber"></span> Risk · Moderate</div>
							<div class="chip-float chip-float--tr" data-depth="-8"><span class="dot dot-green"></span> MSFT · Buy</div>
							<div class="chip-float chip-float--bl" data-depth="8">β · 0.85×</div>
							<div class="chip-float chip-float--br" data-depth="-6"><span class="dot dot-cyan"></span> Theme · dividend income</div>

							<!-- Transient "signal" chips that converge + dissolve on load. -->
							<div class="signals">
								<span class="sig sig-1">AAPL +0.7%</span>
								<span class="sig sig-2">Fed holds</span>
								<span class="sig sig-3">semis ↑</span>
								<span class="sig sig-4">VOO</span>
								<span class="sig sig-5">β 0.85</span>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- ═══ ACT 3 · WORKFLOW ═════════════════════════════════════════ -->
			<section class="act workflow" id="act-workflow" data-hue="teal">
				<div class="act-head reveal">
					<span class="kicker">The workflow</span>
					<h2 class="section-title">Know what changed. Understand why. Decide what to do next.</h2>
				</div>

				<div class="wf-grid">
					<!-- Sticky stage (desktop): one scene plays per active step. -->
					<div class="wf-stage-wrap">
						<div class="wf-stage grad-border" id="wf-stage" data-step="1">
							<!-- Scene 1: ticker chips snap into a table -->
							<div class="wf-scene wf-scene-1">
								<div class="wf-chips">
									<span class="tk">VOO</span><span class="tk">MSFT</span><span class="tk">SCHD</span><span class="tk tk-watch">NVDA</span>
								</div>
								<div class="wf-table">
									<div class="wf-row"><b>VOO</b><span>Core ETF</span><i>18 sh</i></div>
									<div class="wf-row"><b>MSFT</b><span>Stock</span><i>22 sh</i></div>
									<div class="wf-row"><b>SCHD</b><span>Dividend ETF</span><i>60 sh</i></div>
									<div class="wf-row wf-row--watch"><b>NVDA</b><span>Watchlist</span><i>watch</i></div>
								</div>
							</div>
							<!-- Scene 2: radar sweep pings analysis chips -->
							<div class="wf-scene wf-scene-2">
								<div class="wf-radar"><span class="wf-beam"></span><span class="wf-core"></span></div>
								<div class="wf-orbits">
									<span class="an an-1">β 0.85</span><span class="an an-2">HHI 21</span>
									<span class="an an-3">Tech 17%</span><span class="an an-4">3 headlines</span>
									<span class="an an-5">risk-on</span>
								</div>
							</div>
							<!-- Scene 3: verdict card resolves -->
							<div class="wf-scene wf-scene-3">
								<div class="wf-verdict">
									<div class="wf-verdict-head"><b>VOO</b><span class="v-tag">HOLD</span></div>
									<div class="wf-conf"><span class="wf-conf-fill"></span></div>
									<p class="wf-verdict-line">Tracking its index closely — nothing here needs action today.</p>
									<div class="wf-drivers"><span>S&amp;P 500 −0.48%</span><span>Vol 0.6× avg</span></div>
								</div>
							</div>
						</div>
					</div>

					<!-- Step blocks drive the stage as they scroll through. -->
					<ol class="wf-steps">
						{steps.map((s) => (
							<li class="wf-step" data-step={s.n}>
								<span class="wf-num">{s.n}</span>
								<h3>{s.title}</h3>
								<p>{s.body}</p>
								<div class="wf-note"><span class="wf-note-orb"></span><span>{s.senpai}</span></div>
							</li>
						))}
					</ol>
				</div>
			</section>

			<!-- ═══ ACT 4 · FEATURES ═════════════════════════════════════════ -->
			<section class="act features" id="act-features" data-hue="cyan">
				<div class="act-head reveal">
					<span class="kicker">Feature intelligence</span>
					<h2 class="section-title">Every claim, with the product behind it.</h2>
				</div>

				{features.map((f, i) => (
					<article class={`moment reveal accent-${f.accent} ${i % 2 ? 'moment--rev' : ''}`}>
						<div class="moment-copy">
							<span class="kicker">{f.kicker}</span>
							<h3>{f.title}</h3>
							<p>{f.body}</p>
							{f.video && <span class="demo-tag">Demo data · looping</span>}
							{f.senpai && <div class="wf-note"><span class="wf-note-orb"></span><span>{f.senpai}</span></div>}
						</div>
						<figure class="moment-visual">
							<div class="window-chrome window-chrome--sm">
								<div class="window-bar"><span></span><span></span><span></span></div>
								{f.video ? (
									<video class="demo-loop" muted loop playsinline preload="none"
										width="1600" height="1000" poster={demo(`${f.video}-poster.webp`)} aria-label={f.alt}>
										<source src={demo(`${f.video}.mp4`)} type="video/mp4" />
									</video>
								) : (
									<img class="moment-img" src={shot(f.img)} alt={f.alt} loading="lazy" decoding="async" />
								)}
							</div>
						</figure>
					</article>
				))}

				<!-- Moment D — Local-first + live market context (artifact) -->
				<article class="moment reveal accent-green moment--rev moment--artifact">
					<div class="moment-copy">
						<span class="kicker">Local-first · live context</span>
						<h3>Runs on your machine. Watches the whole market.</h3>
						<p>Quotes, history, market regime, and world indices — computed and cached locally. Your database never leaves your laptop.</p>
						<div class="wf-note"><span class="wf-note-orb"></span><span>Your data stays home. The market comes to you.</span></div>
					</div>
					<figure class="moment-visual">
						<div class="artifact artifact-market grad-border">
							<div class="am-head"><span class="am-lock" aria-hidden="true"></span><b>Your machine</b><span class="am-badge">local · encrypted at rest</span></div>
							<div class="am-tape" aria-hidden="true">
								<span class="am-tick up">S&amp;P +0.3%</span><span class="am-tick up">NASDAQ +0.5%</span>
								<span class="am-tick down">FTSE −0.2%</span><span class="am-tick up">Nikkei +0.8%</span>
								<span class="am-tick up">DAX +0.1%</span><span class="am-tick down">HSI −0.4%</span>
								<span class="am-tick up">S&amp;P +0.3%</span><span class="am-tick up">NASDAQ +0.5%</span>
							</div>
							<div class="am-regime"><span class="am-dot"></span> Market regime · <b>Risk-on</b></div>
						</div>
					</figure>
				</article>

				<!-- Moment E — Claude optional (toggle artifact) -->
				<article class="moment reveal accent-peri moment--artifact">
					<div class="moment-copy">
						<span class="kicker">Claude, optional</span>
						<h3>Local by default. Narrated when you want.</h3>
						<p>Add an Anthropic key for briefings, action plans, and news themes. Everything else never needed it.</p>
						<div class="wf-note"><span class="wf-note-orb"></span><span>I’m eloquent either way. Claude just adds adjectives.</span></div>
					</div>
					<figure class="moment-visual">
						<div class="artifact artifact-claude grad-border" id="claude-artifact">
							<div class="ac-toggle"><span class="ac-knob"></span><span class="ac-label ac-label-local">Local</span><span class="ac-label ac-label-claude">Claude</span></div>
							<p class="ac-line ac-line-local">VOO — Hold. Tracking its index; nothing needs action.</p>
							<p class="ac-line ac-line-claude">VOO held its ground as the index drifted — a calm anchor on a choppy Tuesday. Nothing here demands a move; your core is doing exactly its job.</p>
						</div>
					</figure>
				</article>
			</section>

			<!-- ═══ ACT 5 · DEMO PORTFOLIO ═══════════════════════════════════ -->
			<section class="act demo" id="act-demo" data-hue="amber">
				<div class="act-head reveal">
					<span class="kicker">A worked example</span>
					<h2 class="section-title">Demo data. Real workflow.</h2>
					<span class="demo-badge">Demo holdings only · no real portfolio required</span>
				</div>
				<div class="demo-card grad-border reveal" id="demo-card">
					<div class="demo-table" role="table" aria-label="Demo portfolio holdings">
						<div class="demo-row demo-row--head" role="row">
							<span role="columnheader">Holding</span><span role="columnheader">Type</span>
							<span role="columnheader">Allocation</span><span role="columnheader">Verdict</span>
						</div>
						<div class="demo-row" role="row">
							<span role="cell"><strong>VOO</strong> Vanguard S&amp;P 500</span><span role="cell">Core ETF</span>
							<span role="cell"><span class="bar" style="--w:54%"></span>54.1%</span><span role="cell"><em class="v-hold">Hold</em></span>
						</div>
						<div class="demo-row" role="row">
							<span role="cell"><strong>MSFT</strong> Microsoft</span><span role="cell">Stock</span>
							<span role="cell"><span class="bar" style="--w:37%"></span>37.4%</span><span role="cell"><em class="v-buy">Buy</em></span>
						</div>
						<div class="demo-row" role="row">
							<span role="cell"><strong>SCHD</strong> Schwab US Dividend</span><span role="cell">Dividend ETF</span>
							<span role="cell"><span class="bar" style="--w:9%"></span>8.5%</span><span role="cell"><em class="v-hold">Hold</em></span>
						</div>
						<div class="demo-row demo-row--watch" role="row">
							<span role="cell"><strong>NVDA</strong> NVIDIA</span><span role="cell">Watchlist</span>
							<span role="cell">—</span><span role="cell"><em class="v-watch">Research</em></span>
						</div>
					</div>
					<div class="demo-side">
						<div class="demo-stat"><span>Risk</span><strong>Moderate · β 0.85×</strong></div>
						<div class="demo-stat"><span>Sector tilt</span><strong>Technology 17%</strong></div>
						<div class="demo-stat"><span>Concentration</span><strong>Well spread · HHI 21</strong></div>
						<div class="demo-stat"><span>News theme</span><strong>Dividend income</strong></div>
						<p class="demo-note">Risk, news, exposure, and market context — translated into plain English.</p>
					</div>
				</div>
			</section>

			<!-- ═══ ACT 7 · TRUST ════════════════════════════════════════════ -->
			<section class="act trust" id="act-trust" data-hue="teal">
